# ===========================================
# SERVER
# ===========================================
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# ===========================================
# DATABASE
# ===========================================
MONGODB_URI=mongodb://localhost:27017/ai-notes-generator

# ===========================================
# JWT AUTHENTICATION
# ===========================================
JWT_SECRET=replace_this_with_a_long_random_secret_string
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=replace_this_with_another_long_random_secret_string
JWT_REFRESH_EXPIRES_IN=30d

# ===========================================
# GOOGLE GEMINI (AI Summary Generation)
# ===========================================
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# ===========================================
# LOCAL WHISPER (Speech-to-Text)
#
# Transcription runs locally via the openai-whisper Python package.
# No OpenAI API key is required.
#
# Install:
#   pip install openai-whisper
#
# WHISPER_PYTHON_BIN (optional)
#   Path to the Python 3 executable that has whisper installed.
#   Defaults to "python3" (i.e. whatever is first on your PATH).
#   Override if you use a virtualenv or conda environment, e.g.:
#     WHISPER_PYTHON_BIN=/home/you/.venv/bin/python
#     WHISPER_PYTHON_BIN=C:\Users\you\AppData\Local\Programs\Python\Python311\python.exe
#
# WHISPER_MODEL (optional)
#   Model size to use.  Larger = more accurate, but slower and more RAM.
#   Options:  tiny | base | small | medium | large
#   Default:  base  (~140 MB, good balance of speed and accuracy on CPU)
#   Recommended for GPU machines:  small or medium
# ===========================================
WHISPER_PYTHON_BIN=python3
WHISPER_MODEL=base

# ===========================================
# CLOUDINARY (File Storage)
# ===========================================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ===========================================
# EMAIL (Forgot Password)
# ===========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=AI Notes Generator <no-reply@ainotes.com>

# ===========================================
# RATE LIMITING
# ===========================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200
